# Bifrost environment file. Copy to /etc/bifrost/bifrost.env, chmod 0600,
# owned by root:bifrost.

# Required: 32-byte master key, hex (64 chars) or base64. Generate with:
#   openssl rand -hex 32
# BACK THIS UP. Losing it means encrypted SMTP credentials become unreadable.
BIFROST_MASTER_KEY=replace_me_with_64_hex_chars

# Optional bootstrap admin (used only when no admin row exists yet).
# Remove or change after the first start.
BIFROST_ADMIN_USERNAME=admin
BIFROST_ADMIN_PASSWORD=change_me_on_first_login

# Optional: built-in TLS. Usually you'd let Caddy/nginx terminate instead.
# BIFROST_TLS_CERT=/etc/bifrost/cert.pem
# BIFROST_TLS_KEY=/etc/bifrost/key.pem

# Optional tunables
# BIFROST_LISTEN_ADDR=127.0.0.1:8080
# BIFROST_WORKER_INTERVAL=1s
# BIFROST_SHUTDOWN_GRACE=30s
