# Postern environment file. Copy to /etc/postern/postern.env, chmod 0600,
# owned by root:postern.

# Required: 32-byte master key, hex (64 chars) or base64. Generate with:
#   openssl rand -hex 32
# BACK THIS UP. Losing it means encrypted SMTP credentials become unreadable.
POSTERN_MASTER_KEY=replace_me_with_64_hex_chars

# Optional bootstrap admin (used only when no admin row exists yet).
# Remove or change after the first start.
POSTERN_ADMIN_USERNAME=admin
POSTERN_ADMIN_PASSWORD=change_me_on_first_login

# Optional: built-in TLS. Usually you'd let Caddy/nginx terminate instead.
# POSTERN_TLS_CERT=/etc/postern/cert.pem
# POSTERN_TLS_KEY=/etc/postern/key.pem

# Optional tunables
# POSTERN_LISTEN_ADDR=127.0.0.1:8080
# POSTERN_WORKER_INTERVAL=1s
# POSTERN_SHUTDOWN_GRACE=30s

# Reverse-proxy deployment (e.g. Caddy/nginx terminating TLS). Set both true so
# forwarded headers are trusted and cookies keep the Secure attribute.
# POSTERN_TRUST_PROXY=true
# POSTERN_SECURE_COOKIES=true
