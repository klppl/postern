# Postern environment file. Copy to .env (which is gitignored) and edit.
# Shell-exported variables override anything set here.

# Required: 32-byte master key. Generate with `openssl rand -hex 32`.
# BACK THIS UP — losing it means encrypted SMTP credentials in the DB
# become unrecoverable.
POSTERN_MASTER_KEY=replace_me_with_64_hex_chars

# Bootstrap admin (only used the first time, when no admin row exists).
POSTERN_ADMIN_USERNAME=admin
POSTERN_ADMIN_PASSWORD=changeme

# Optional
# POSTERN_LISTEN_ADDR=:8080
# POSTERN_DB_PATH=postern.db
# POSTERN_TLS_CERT=/etc/postern/cert.pem
# POSTERN_TLS_KEY=/etc/postern/key.pem
# POSTERN_WORKER_INTERVAL=1s
# POSTERN_SHUTDOWN_GRACE=30s
