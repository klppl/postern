# Bifrost environment file. Copy to .env (which is gitignored) and edit.
# Shell-exported variables override anything set here.

# Required: 32-byte master key. Generate with `openssl rand -hex 32`.
# BACK THIS UP — losing it means encrypted SMTP credentials in the DB
# become unrecoverable.
BIFROST_MASTER_KEY=replace_me_with_64_hex_chars

# Bootstrap admin (only used the first time, when no admin row exists).
BIFROST_ADMIN_USERNAME=admin
BIFROST_ADMIN_PASSWORD=changeme

# Optional
# BIFROST_LISTEN_ADDR=:8080
# BIFROST_DB_PATH=bifrost.db
# BIFROST_TLS_CERT=/etc/bifrost/cert.pem
# BIFROST_TLS_KEY=/etc/bifrost/key.pem
# BIFROST_WORKER_INTERVAL=1s
# BIFROST_SHUTDOWN_GRACE=30s
